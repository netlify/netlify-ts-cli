{
  "name": "@netlify/ts-cli",
  "version": "1.0.2",
  "description": "Create TanStack Start applications for Netlify",
  "bin": "./dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "check-outdated": "node scripts/check-outdated-packages.js",
    "update-packages": "node scripts/check-outdated-packages.js --update"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/netlify/netlify-ts-cli.git"
  },
  "homepage": "https://netlify.com",
  "keywords": [
    "netlify",
    "tanstack"
  ],
  "author": "Jack Herrington <jack.herrington@netlify.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "validate-npm-package-name": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/validate-npm-package-name": "^4.0.2",
    "semver": "^7.6.3",
    "typescript": "^5.6.3"
  }
}
